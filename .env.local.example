GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=drinkingwine/vacation-photos
# GITHUB_BRANCH=main

# Cloudflare R2 (required for photo/video storage)
# Run: npx wrangler login && npm run setup:r2
# Or set CLOUDFLARE_API_TOKEN (Account → R2 → Edit) and run npm run setup:r2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=vacation-photos
R2_BACKUP_BUCKET_NAME=vacation-photos-backup
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Auth (required)
SESSION_SECRET=generate-a-long-random-string
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password

# Google Maps (optional — required for /map page)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Optional: custom Map ID for production (defaults to DEMO_MAP_ID for dev)
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your-map-id

# lightGallery license (required for production — get a personal key at lightgalleryjs.com)
# NEXT_PUBLIC_LIGHTGALLERY_LICENSE_KEY=your-lightgallery-license-key

# Positionstack (optional — geo locator falls back to OpenStreetMap Nominatim without it)
# POSITIONSTACK_ACCESS_KEY=your-positionstack-access-key
